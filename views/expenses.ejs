<%- include("partials/head", { title: "Expenses", css: ["/css/base.css"] }) %>

  <body>
    <!-- Navbar -->
    <%- include("partials/navbar") %>

    <!-- Main Content -->
    <div class="container mt-5 habit-containter">
      <div class="row g-4">
        <!-- Budget Section -->
        <div class="col-12">
          <div class="card p-3 app-card mb-2">
            <h4>Monthly Budget</h4>
            <h5 id="monthly-budget">৳ 0</h5>
            <div class="progress mt-3">
              <div id="budget-bar" class="progress-bar"></div>
            </div>

            <span
              id="budget-warning"
              class="badge mt-2"
              style="display: none"
            ></span>

            <!-- Budget Form -->
            <form action="/set-budget" method="POST" id="budget-form">
              <input
                type="number"
                name="amount"
                class="form-control mt-2"
                placeholder="Place your budget"
                required
              />
              <button class="btn btn-primary w-100 mt-3">Add Budget</button>
            </form>

            <!-- Change / Reset Budget Buttons -->
            <div id="budget-actions" style="display: none">
              <button
                class="btn btn-outline-info w-100 mt-2"
                onclick="window.location.href = '/reset-budget'"
                id="change-budget-btn"
              >
                Change Budget
              </button>
              <button
                class="btn btn-outline-danger w-100 mt-2"
                onclick="confirmResetBudget()"
              >
                Reset Budget
              </button>
            </div>
          </div>
        </div>

        <!-- Expense Section -->
        <!-- Expense Section -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h4>Add Expense</h4>

            <form method="POST" action="/add-expense">
              <input
                type="text"
                name="name"
                class="form-control mb-2 mt-2"
                placeholder="Enter expense name"
                required
              />
              <input
                type="number"
                name="amount"
                class="form-control mt-2"
                placeholder="Place your expense amount"
                required
              />
              <button class="btn btn-primary w-100 mt-3">Add Expense</button>
            </form>
          </div>
        </div>

        <!-- Expense List -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h4>Expense List</h4>
            <ul class="list-unstyled p-0 border-0 mt-3" id="expense-list">
              <!-- Populated via JS -->
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <%- include("partials/footer") %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module">
      import { initExpenses } from "/js/expenses.js";
      initExpenses();
    </script>

    <script>
      function confirmResetBudget() {
        if (
          confirm(
            "Are you sure you want to reset your budget? All budget data for this month will be deleted.",
          )
        ) {
          window.location.href = "/reset-budget";
        }
      }
    </script>
  </body>
</html>
