<%- include("partials/head", { title: "Habits", css: ["/css/base.css"] }) %>

  <body>
    <!--Navbar-->
    <%- include("partials/navbar") %>

    <!--Adding habits with difficulty scoring section-->
    <div class="container mt-5 habit-containter">
      <div class="row g-4">
        <div class="col-12">
          <div class="card p-3 app-card">
            <h4>Add Habit</h4>
            <form action="/add-habit" method="POST" id="add-habit-form">
              <input
                type="text"
                name="name"
                class="form-control mb-2 mt-2"
                placeholder="Enter habit name"
                required
              />

              <input
                type="number"
                name="difficulty"
                id="difficulty-input"
                class="form-control mt-2"
                placeholder="Place a value between 1-10"
                min="1"
                max="10"
                required
              />
              <div
                id="difficulty-error"
                class="text-danger mt-1"
                style="display: none; font-size: 0.875rem"
              >
                Difficulty must be between 1 and 10.
              </div>

              <select name="category" class="form-control mt-2">
                <option value="physical">Physical</option>
                <option value="spiritual">Spiritual</option>
                <option value="healthy">Healthy</option>
              </select>

              <button
                type="button"
                class="btn btn-primary w-100 mt-3"
                onclick="validateAndSubmitHabit()"
              >
                Add Habit
              </button>
            </form>
          </div>
        </div>

        <div class="col-12">
          <div class="card p-3 app-card mb-4">
            <h4>Total Streak Points</h4>
            <h5 id="streak-points">🔥 0</h5>
          </div>
        </div>
        <div class="d-flex gap-2 mb-3">
          <button
            class="btn btn-outline-light btn-sm"
            onclick="filterHabits('all')"
          >
            All
          </button>
          <button
            class="btn btn-outline-info btn-sm"
            onclick="filterHabits('physical')"
          >
            Physical
          </button>
          <button
            class="btn btn-outline-warning btn-sm"
            onclick="filterHabits('spiritual')"
          >
            Spiritual
          </button>
          <button
            class="btn btn-outline-success btn-sm"
            onclick="filterHabits('healthy')"
          >
            Healthy
          </button>
        </div>

        <div class="col-12">
          <div class="card p-3 app-card">
            <div class="d-flex justify-content-between align-items-center">
              <h4>Habit List</h4>
              <button
                class="btn btn-outline-danger btn-sm"
                onclick="confirmResetHabits()"
              >
                Reset All Habits
              </button>
            </div>
            <ul
              class="list-group mt-3 list-unstyled p-0 border-0"
              id="habit-list"
            >
              <!-- Habit items will be added here dynamically -->
            </ul>
          </div>
        </div>
      </div>
    </div>

    <%- include("partials/footer") %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
    <script type="module">
      import { initHabits } from "/js/habits.js";
      initHabits();
    </script>

    <script>
      function validateAndSubmitHabit() {
        const difficulty = Number(
          document.querySelector("#difficulty-input").value,
        );
        const errorEl = document.querySelector("#difficulty-error");

        if (difficulty < 1 || difficulty > 10) {
          errorEl.style.display = "block";
          return;
        }

        errorEl.style.display = "none";
        document.querySelector("#add-habit-form").submit();
      }

      function confirmResetHabits() {
        if (
          confirm(
            "Are you sure you want to delete ALL habits? This cannot be undone.",
          )
        ) {
          window.location.href = "/reset-habits";
        }
      }
    </script>
  </body>
</html>
