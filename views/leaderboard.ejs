<%- include("partials/head", { title: "Leaderboard", css: ["/css/base.css"] }) %>

  <body>
    <!-- Leaderboard page: see how users rank by daily streak points -->
    <!-- Navbar -->
    <%- include("partials/navbar") %>

    <!-- Leaderboard -->
    <div class="container mt-5">
      <div class="row g-4">
        <div class="col-12">
          <div class="card p-4 app-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h3 class="mb-0">🏆 Leaderboard</h3>
              <span class="badge bg-primary fs-6">Today's Streak Points</span>
            </div>

            <ul class="list-unstyled p-0 m-0" id="leaderboard-list">
              <!-- Populated via JS -->
            </ul>
          </div>
        </div>
      </div>
    </div>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module">
      import { initLeaderboard } from "/js/leaderboard.js";
      initLeaderboard();
    </script>
  </body>
</html>
