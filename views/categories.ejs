<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categories</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Use same styling as habits -->
    <link rel="stylesheet" href="/css/categories.css" />
  </head>

  <body>
    <!-- NAVBAR -->
    <%- include("partials/navbar") %>

    <!-- CONTENT -->
    <div class="container mt-5 habit-container">
      <h3 class="mb-4 text-center">Add Habits from Categories</h3>

      <div class="row g-4">
        <!-- PHYSICAL -->
        <div class="col-12">
          <div class="card p-3 habit-card">
            <h5 class="mb-3">Physical</h5>

            <!-- Running -->
            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Running"
                  data-difficulty="5"
                  data-category="physical"
                  onchange="togglePresetHabit(this)"
                />
                <span>Running</span>
              </div>
              <span class="badge text-dark">🔥 5</span>
            </div>

            <!-- Pushups -->
            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Pushups"
                  data-difficulty="7"
                  data-category="physical"
                  onchange="togglePresetHabit(this)"
                />
                <span>Pushups</span>
              </div>
              <span class="badge text-dark">🔥 7</span>
            </div>

            <!-- Cycling -->
            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Cycling"
                  data-difficulty="6"
                  data-category="physical"
                  onchange="togglePresetHabit(this)"
                />
                <span>Cycling</span>
              </div>
              <span class="badge text-dark">🔥 6</span>
            </div>
          </div>
        </div>

        <!-- SPIRITUAL -->
        <div class="col-12">
          <div class="card p-3 habit-card">
            <h5 class="mb-3">Spiritual</h5>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Meditation"
                  data-difficulty="4"
                  data-category="spiritual"
                  onchange="togglePresetHabit(this)"
                />
                <span>Meditation</span>
              </div>
              <span class="badge text-dark">🔥 4</span>
            </div>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Prayer"
                  data-difficulty="3"
                  data-category="spiritual"
                  onchange="togglePresetHabit(this)"
                />
                <span>Prayer</span>
              </div>
              <span class="badge text-dark">🔥 3</span>
            </div>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Gratitude Journal"
                  data-difficulty="5"
                  data-category="spiritual"
                  onchange="togglePresetHabit(this)"
                />
                <span>Gratitude Journal</span>
              </div>
              <span class="badge text-dark">🔥 5</span>
            </div>
          </div>
        </div>

        <!-- HEALTHY -->
        <div class="col-12">
          <div class="card p-3 habit-card">
            <h5 class="mb-3">Healthy</h5>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Drink Water"
                  data-difficulty="2"
                  data-category="healthy"
                  onchange="togglePresetHabit(this)"
                />
                <span>Drink Water</span>
              </div>
              <span class="badge text-dark">🔥 2</span>
            </div>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Sleep Early"
                  data-difficulty="6"
                  data-category="healthy"
                  onchange="togglePresetHabit(this)"
                />
                <span>Sleep Early at 10AM</span>
              </div>
              <span class="badge text-dark">🔥 6</span>
            </div>

            <div
              class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center"
            >
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="Eat Healthy"
                  data-difficulty="5"
                  data-category="healthy"
                  onchange="togglePresetHabit(this)"
                />
                <span>Eat Healthy</span>
              </div>
              <span class="badge text-dark">🔥 5</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Back button -->
      <div class="text-center my-3">
        <a href="/habits" class="btn btn-primary">Go to Habits</a>
      </div>
    </div>

    <%- include("partials/footer") %>
    <!-- JS -->
    <script src="/js/index.js"></script>
  </body>
</html>
