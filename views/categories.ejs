<%- include("partials/head", { title: "Categories", css: ["/css/base.css"] }) %>

  <body>
    <!-- Navigation bar - shared across all pages -->
    <%- include("partials/navbar") %>

    <!-- Main content container -->
    <div class="container mt-5 habit-container">
      <!-- Page title -->
      <h3 class="mb-4 text-center">Add Habits from Categories</h3>

      <!-- Bootstrap grid layout for categories -->
      <div class="row g-4">
        <!-- PHYSICAL category section -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <!-- Category title -->
            <h5 class="mb-3">Physical</h5>
            <!-- Loop through physical habits and render each one -->
            <% presetHabits.physical.forEach(habit => { %>
            <div class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center">
              <div class="d-flex align-items-center gap-2">
                <!-- Checkbox to add/remove habit - uses data attributes for JavaScript -->
                <input
                  type="checkbox"
                  data-name="<%= habit.name %>"
                  data-difficulty="<%= habit.difficulty %>"
                  data-category="physical"
                  onchange="togglePresetHabit(this)"
                />
                <!-- Display habit name (uses displayName if available, otherwise name) -->
                <span><%= habit.displayName || habit.name %></span>
              </div>
              <!-- Show difficulty as fire emoji with number -->
              <span class="badge text-dark">🔥 <%= habit.difficulty %></span>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- SPIRITUAL category section -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h5 class="mb-3">Spiritual</h5>
            <!-- Loop through spiritual habits -->
            <% presetHabits.spiritual.forEach(habit => { %>
            <div class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center">
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="<%= habit.name %>"
                  data-difficulty="<%= habit.difficulty %>"
                  data-category="spiritual"
                  onchange="togglePresetHabit(this)"
                />
                <span><%= habit.displayName || habit.name %></span>
              </div>
              <span class="badge text-dark">🔥 <%= habit.difficulty %></span>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- HEALTHY category section -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h5 class="mb-3">Healthy</h5>
            <!-- Loop through healthy habits -->
            <% presetHabits.healthy.forEach(habit => { %>
            <div class="card mb-2 p-2 d-flex flex-row justify-content-between align-items-center">
              <div class="d-flex align-items-center gap-2">
                <input
                  type="checkbox"
                  data-name="<%= habit.name %>"
                  data-difficulty="<%= habit.difficulty %>"
                  data-category="healthy"
                  onchange="togglePresetHabit(this)"
                />
                <span><%= habit.displayName || habit.name %></span>
              </div>
              <span class="badge text-dark">🔥 <%= habit.difficulty %></span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Back button to return to habits page -->
      <div class="text-center my-3">
        <a href="/habits" class="btn btn-primary">Go to Habits</a>
      </div>
    </div>

    <!-- Footer - shared across all pages -->
    <%- include("partials/footer") %>
    <!-- Load JavaScript for interactive features -->
    <script type="module">
      import { initCategories } from "/js/categories.js";
      initCategories();
    </script>
  </body>
</html>
