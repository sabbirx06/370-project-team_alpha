<%- include("partials/head", { title: "Savings", css: ["/css/base.css"] }) %>

  <body>
    <!-- Savings page: add savings goals and track progress -->
    <!-- Navbar -->
    <%- include("partials/navbar") %>

    <div class="container mt-5">
      <div class="row g-4">
        <!-- Add Goal -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h4>Add Savings Goal</h4>
            <form action="/add-goal" method="POST">
              <input
                name="name"
                class="form-control mb-2 mt-2"
                placeholder="Goal name (e.g. New Laptop)"
                required
              />
              <input
                name="target"
                type="number"
                class="form-control mt-2"
                placeholder="Target amount (৳)"
                min="1"
                required
              />
              <button class="btn btn-primary w-100 mt-3">Add Goal</button>
            </form>
          </div>
        </div>

        <!-- Goals List -->
        <div class="col-12">
          <div class="card p-3 app-card">
            <h4>Your Goals</h4>
            <ul class="list-unstyled p-0 border-0 mt-3" id="goals-list">
              <!-- Populated via JS -->
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module">
      import { initSavings } from "/js/savings.js";
      initSavings();
    </script>
  </body>
</html>
