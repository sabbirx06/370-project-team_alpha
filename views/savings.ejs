<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Savings</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="icon" href="/media/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <!-- Navbar -->
    <%- include("partials/navbar") %>

    <div class="container mt-5">
      <div class="row g-4">
        <!-- Add Goal -->
        <div class="col-12">
          <div class="card p-3 habit-card">
            <h4>Add Savings Goal</h4>
            <form action="/add-goal" method="POST">
              <input
                name="name"
                class="form-control mb-2 mt-2"
                placeholder="Goal name (e.g. New Laptop)"
                required
              />
              <input
                name="target"
                type="number"
                class="form-control mt-2"
                placeholder="Target amount (৳)"
                min="1"
                required
              />
              <button class="btn btn-primary w-100 mt-3">Add Goal</button>
            </form>
          </div>
        </div>

        <!-- Goals List -->
        <div class="col-12">
          <div class="card p-3 habit-card">
            <h4>Your Goals</h4>
            <ul class="list-unstyled p-0 border-0 mt-3" id="goals-list">
              <!-- Populated via JS -->
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/savings.js"></script>
  </body>
</html>
